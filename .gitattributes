# Автоматическая нормализация line endings
* text=auto eol=lf

# Явно LF для всех исполняемых и конфигурационных файлов
*.sh    text eol=lf
*.py    text eol=lf
*.ini   text eol=lf
*.mako  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.html  text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.json  text eol=lf
*.cfg   text eol=lf
*.env   text eol=lf