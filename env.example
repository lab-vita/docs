# Bitrix24 OAuth
CLIENT_ID=local.xxxxxx
CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
APP_URL=https://docs.lab-vita.ru

# Bitrix24 Webhook (для загрузки файлов на Диск)
BITRIX_WEBHOOK_URL=https://your-portal.bitrix24.ru/rest/USER_ID/TOKEN/

# База данных PostgreSQL
DATABASE_URL=postgresql+asyncpg://labvita:your_password@postgres:5432/labvita
DB_PASSWORD=your_password

# Администраторы приложения (user_id через запятую)
ADMIN_USER_IDS=1,5,12

# Поле подписи в инфокарте сотрудника
SIGN_FIELD=UF_USR_1784019697611

# --- Ниже используется только при первом seed (можно убрать после) ---
# ID инфоблока процесса "Выдача наличных"
CASH_REQUEST_IBLOCK_ID=94
# ID шаблона БП
CASH_REQUEST_BP_ID=592
# Код поля суммы в инфоблоке
FIELD_SUMMA=PROPERTY_516
# Код поля назначения платежа
FIELD_NAZNACHENIE=PROPERTY_518
